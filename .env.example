# CIRO Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google Gemini API (for AI-powered agent reasoning)
GEMINI_API_KEY=your_gemini_api_key_here

# Weather Data API
METEOSOURCE_API_KEY=your_meteosource_api_key_here

# Traffic Data API
TOMTOM_API_KEY=your_tomtom_api_key_here

# Firebase / Firestore Configuration
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_DATABASE_ID=cirokhi

# Application Settings
LOG_LEVEL=INFO
SIMULATION_MODE=true
# Set SIMULATION_MODE=false to enable live Gemini + Firestore
